<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:layout_width="288dp"
        android:layout_height="84dp"
        android:src="@drawable/vectoroperacioness" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="101dp"
        android:fontFamily="@font/DemodeCapitals"
        android:text="OMABA"
        android:textColor="@color/white"
        android:textSize="70dp" />

    <TextView
        android:textSize="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="select your difficulty!"
        android:textColor="#CE93D8"/>

    <RadioGroup android:id="@+id/rgDifficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <RadioButton android:id="@+id/rbEasy"
            android:text="Easy"
            android:textSize="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#33FF00"
            />
        <RadioButton android:id="@+id/rbMedium"
            android:text="Medium"
            android:textSize="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFF00"
            />
        <RadioButton android:id="@+id/rbHard"
            android:text="Hard"
            android:textSize="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            />
    </RadioGroup>

    <Button
        android:id="@+id/btnStart"
        android:text="Start"
        android:textSize="20dp"
        android:textColor="@color/black"
        android:backgroundTint="#FFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        />

</LinearLayout>
